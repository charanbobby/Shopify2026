# Ignore all files by default
*

# Allow directories
!docs/
!docs/css/
!docs/js/
!overrides/
!overrides/partials/
!overrides/partials/*.html
# Allow markdown files
!*.md

# Allow mkdocs config, Netlify config, and dependencies
!mkdocs.yml
!netlify.toml
!requirements.txt

# Allow deploy script
!*.sh

# Allow .gitignore itself
!.gitignore

# Never track generated site output
site/
