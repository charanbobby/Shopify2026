# Ignore all files by default
*

# Allow directories
!docs/
!docs/css/
!docs/js/
!overrides/
!overrides/partials/
!overrides/partials/*.html
!.github/
!.github/workflows/
!.github/workflows/*.yml
# Allow markdown files
!*.md

# Allow mkdocs config and dependencies
!mkdocs.yml
!requirements.txt

# Allow deploy script
!*.sh

# Allow .gitignore itself
!.gitignore

# Never track generated site output
site/
