# Ignore all files by default
*

# Allow directories
!docs/
!docs/css/
!docs/js/
!overrides/

# Allow HTML overrides
!*.html

# Allow markdown files
!*.md

# Allow mkdocs config, Netlify config, and dependencies
!mkdocs.yml
!netlify.toml
!requirements.txt

# Allow Giscus assets
!*.css
!*.js

# Allow deploy script
!*.sh

# Allow .gitignore itself
!.gitignore

# Never track generated site output
site/
